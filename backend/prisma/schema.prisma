// Prisma schema for ERP Digital Printing Pixelso
// Generated from ERD in BRD_PRD_ERD dokumen "Versi Sempurna" (section 4)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ---------- M01: User & Role Management ----------

model Role {
  roleId        Int      @id @default(autoincrement()) @map("role_id")
  roleName      String   @unique @map("role_name")
  permissionSet Json?    @map("permission_set")
  users         User[]

  @@map("roles")
}

model Team {
  teamId Int    @id @default(autoincrement()) @map("team_id")
  name   String
  users  User[]

  @@map("teams")
}

model User {
  userId     Int      @id @default(autoincrement()) @map("user_id")
  name       String
  email      String   @unique
  password   String
  roleId     Int      @map("role_id")
  teamId     Int?     @map("team_id")
  status     String   @default("active")
  isSystem   Boolean  @default(false) @map("is_system") // akun placeholder non-manusia (mis. checkout storefront)
  createdAt  DateTime @default(now()) @map("created_at")

  role Role  @relation(fields: [roleId], references: [roleId])
  team Team? @relation(fields: [teamId], references: [teamId])

  designedOrders    ProductionOrder[] @relation("designer")
  cashierSales      SalesPos[]        @relation("cashier")
  operatorTasks     ProductionTask[]  @relation("operator")
  qcChecks          QcCheck[]         @relation("qc_by")
  bonusRecords      BonusRecord[]
  dailyKpis         DailyKpi[]
  notifications     Notification[]
  confirmedPayments Payment[]
  expenses          Expense[]
  purchaseOrders    PurchaseOrder[]

  @@map("users")
}

// ---------- M02: Customer & CRM ----------

model Customer {
  customerId Int      @id @default(autoincrement()) @map("customer_id")
  legacyId   String?  @unique @map("legacy_id") // idpelanggan dari POS lama (mis. 'PL00001') - cuma diisi hasil migrasi, lihat migrate-legacy-data.js
  name       String
  phone      String?
  email      String?  @unique // NEW, nullable - row lama (walk-in, dibuat staf) tetap valid tanpa email
  password   String?  // NEW, nullable - hash bcrypt, cuma diisi akun self-service storefront
  googleId   String?  @unique @map("google_id") // sub claim dari Google ID token, dipakai akun "Login dengan Google"
  resetTokenHash      String?   @map("reset_token_hash") // SHA-256 dari token reset password mentah (mentahnya cuma dikirim lewat email, tidak pernah disimpan)
  resetTokenExpiresAt DateTime? @map("reset_token_expires_at")
  segment    String?
  source     String?
  createdAt  DateTime @default(now()) @map("created_at")

  productionOrders ProductionOrder[]

  @@map("customers")
}

// ---------- M03: Production Order / PO ----------

model Product {
  productId      Int           @id @default(autoincrement()) @map("product_id")
  legacyId       String?       @unique @map("legacy_id") // idproduk dari POS lama (mis. 'PR00001') - cuma diisi hasil migrasi, lihat migrate-legacy-data.js
  name           String
  categoryId     Int?          @map("category_id")
  basePrice      Decimal       @default(0) @map("base_price") @db.Decimal(14, 2) // Harga Retail
  priceGrosir1   Decimal?      @map("price_grosir1") @db.Decimal(14, 2)
  priceGrosir23  Decimal?      @map("price_grosir23") @db.Decimal(14, 2) // gabungan tingkat Grosir 2 & 3
  priceHpp       Decimal?      @map("price_hpp") @db.Decimal(14, 2) // harga pokok/modal
  unit           String?
  printProductId Int?          @unique @map("print_product_id") // NEW - link ke katalog storefront (PrintProduct)
  pricingMode    String        @default("unit") @map("pricing_mode") // referensi PricingMode.key (bukan FK, sama seperti PrintProduct.pricingMode) - dipakai form Buat PO untuk tentukan input Lebar x Tinggi (area) vs Qty saja (scalar)

  poDetails    PoDetail[]
  printProduct PrintProduct? @relation(fields: [printProductId], references: [printProductId])
  category     Category?     @relation(fields: [categoryId], references: [categoryId])

  @@map("products")
}

// ---------- Identitas & konten halaman depan storefront (satu-satunya sumber, mis. pricing di atas) ----------

model SiteSettings {
  id            Int      @id @default(1) // baris tunggal (singleton), dijaga di level aplikasi bukan DB
  name          String   @default("Pixelso Gemolong")
  tagline       String?
  description   String?  @db.Text
  address       String?  @db.Text
  openingHours  String?  @map("opening_hours")
  whatsapp      String?
  instagram     String?
  tiktok        String?
  youtube       String?
  facebook      String?
  heroImageUrl  String?  @map("hero_image_url") // deprecated - dipertahankan cuma buat backfill, sudah tidak dibaca aplikasi, lihat heroSlides
  heroSlides    Json?    @map("hero_slides") // array {url, linkUrl} maks 5 - slideshow hero halaman depan, tiap slide bisa diklik
  galleryImages Json?    @map("gallery_images") // array {url, caption} - foto pendukung
  updatedBy     Int?     @map("updated_by")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

// Tema event storefront (Kemerdekaan, Idul Fitri, dsb) - manager buat beberapa tema di muka,
// aktifkan salah satu kapan perlu (manual, bukan terjadwal). Cuma satu boleh isActive:true,
// dijaga di theme.service.js#activate() lewat transaction, bukan constraint DB.
model Theme {
  themeId    Int      @id @default(autoincrement()) @map("theme_id")
  name       String
  isActive   Boolean  @default(false) @map("is_active")
  colors     Json? // { "--maroon-950": "#2a0710", ... } subset dari CSS var index.css storefront yang boleh dioverride
  logoUrl    String?  @map("logo_url")
  heroSlides Json?    @map("hero_slides") // array {url, linkUrl} - override SiteSettings.heroSlides selama tema ini aktif; kosong/null = pakai hero normal
  customCss  String?  @map("custom_css") @db.Text // disuntik manager, dipercaya sama seperti akses master-data lain (bukan input publik)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("themes")
}

// ---------- Harga website publik (satu-satunya sumber untuk kalkulator landing page) ----------
// Bentuknya mengikuti data/config.json (pricing) di app pixelso_nodejs - lihat ERP_INTEGRATION.md di app itu.

model PricingSetting {
  id              Int      @id @default(1) // baris tunggal (singleton), dijaga di level aplikasi bukan DB
  designFee       Decimal  @default(0) @map("design_fee") @db.Decimal(14, 2)
  materialFactors Json     @map("material_factors")
  finishingRates  Json     @map("finishing_rates")
  updatedBy       Int?     @map("updated_by")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("pricing_settings")
}

model PrintProduct {
  printProductId Int      @id @default(autoincrement()) @map("print_product_id")
  key            String   @unique
  name           String
  pricingMode    String   @map("pricing_mode") // 'area' | 'unit'
  categoryId     Int?     @map("category_id") // grup untuk menu kategori storefront - lihat model Category
  baseRate       Decimal  @default(0) @map("base_rate") @db.Decimal(14, 2)
  minimumArea    Decimal  @default(0) @map("minimum_area") @db.Decimal(10, 4)
  setupFee       Decimal  @default(0) @map("setup_fee") @db.Decimal(14, 2)
  isActive       Boolean  @default(true) @map("is_active")
  sortOrder      Int      @default(0) @map("sort_order")
  imageUrl       String?  @map("image_url") // dicache = images[0] - foto utama/thumbnail, sumber kebenaran ada di images
  images         Json? // array URL foto, maks 4, index 0 = thumbnail utama/pilihan manager
  videoUrl       String?  @map("video_url") // link video produk (YouTube/Instagram/TikTok), bukan file upload
  description    String?  @db.Text // deskripsi singkat 1-2 kalimat, tampil di halaman detail storefront
  specs          Json? // daftar poin spesifikasi teknis, array string, mis. ["Bahan flexi korea", "Anti air"]
  updatedBy      Int?     @map("updated_by")
  updatedAt      DateTime @updatedAt @map("updated_at")

  product      Product? // NEW - reverse relation ke Product operasional (untuk PoDetail checkout storefront)
  category     Category?             @relation(fields: [categoryId], references: [categoryId])
  optionGroups ProductOptionGroup[]

  @@map("print_products")
}

// Varian/opsi per produk untuk Form Order storefront (mis. Bahan, Finishing, Laminasi) -
// tiap produk punya set grup sendiri, beda dari produk lain (lihat pricing.service.js).
model ProductOptionGroup {
  groupId        Int      @id @default(autoincrement()) @map("group_id")
  printProductId Int      @map("print_product_id")
  label          String // "Bahan", "Finishing", "Laminasi", dst
  required       Boolean  @default(true)
  sortOrder      Int      @default(0) @map("sort_order")

  printProduct PrintProduct          @relation(fields: [printProductId], references: [printProductId], onDelete: Cascade)
  choices      ProductOptionChoice[]

  @@map("product_option_groups")
}

model ProductOptionChoice {
  choiceId   Int      @id @default(autoincrement()) @map("choice_id")
  groupId    Int      @map("group_id")
  label      String // "Stiker Chromo", "Tanpa Laminasi", dst
  priceMode  String   @map("price_mode") // 'replace_base' | 'multiplier' | 'add'
  priceValue Decimal  @default(0) @map("price_value") @db.Decimal(14, 2)
  perUnit    Boolean  @default(false) @map("per_unit") // priceMode 'add': kali qty atau flat sekali
  isDefault  Boolean  @default(false) @map("is_default")
  sortOrder  Int      @default(0) @map("sort_order")
  qtyTiers   Json?    @map("qty_tiers") // opsional: [{minQty, maxQty|null, price}] naik per minQty - kalau null/kosong pakai priceValue flat seperti biasa, lihat calculatePrintPrice

  group ProductOptionGroup @relation(fields: [groupId], references: [groupId], onDelete: Cascade)

  @@map("product_option_choices")
}

model Category {
  categoryId Int      @id @default(autoincrement()) @map("category_id")
  name       String   @unique
  createdAt  DateTime @default(now()) @map("created_at")

  products      Product[]
  printProducts PrintProduct[]

  @@map("categories")
}

// Master Supplier - dari migrasi data POS lama (migrate-legacy-data.js). Belum ada relasi ke
// Material/Product (mis. "produk ini dari supplier X") - itu fitur pembelian terpisah, di luar
// cakupan migrasi data ini, cuma tempat menyimpan datanya dulu.
model Supplier {
  supplierId Int      @id @default(autoincrement()) @map("supplier_id")
  legacyId   String?  @unique @map("legacy_id") // idsupplier dari POS lama (mis. 'SU001')
  name       String
  address    String?
  phone      String?
  contact    String?
  createdAt  DateTime @default(now()) @map("created_at")

  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

// Master Mode Harga - daftar mode kalkulasi harga yang bisa dipilih staf saat bikin PrintProduct
// (mis. "Per m²", "Per Pcs", "Per Menit", "Per Gram"). Lookup/metadata saja - PrintProduct.pricingMode
// tetap String biasa (bukan FK) supaya tidak perlu migrasi data & kontrak string yang sudah dipakai
// calculator/API publik tidak berubah. Lihat pricing.service.js untuk validasi & enrichment.
model PricingMode {
  modeId     Int      @id @default(autoincrement()) @map("mode_id")
  key        String   @unique // slug, immutable setelah dibuat (direferensikan sebagai string oleh PrintProduct.pricingMode)
  label      String // "Per m²", "Per Pcs", "Per Menit", "Per Gram" - ditampilkan di dropdown & tabel
  calcType   String   @default("scalar") @map("calc_type") // 'area' (butuh lebar x tinggi) | 'scalar' (satu angka: pcs/menit/gram/dst)
  unitLabel  String   @map("unit_label") // "m²", "pcs", "menit", "gram" - suffix singkat buat tampilan storefront
  inputLabel String   @map("input_label") // label field form storefront, mis. "Durasi (menit)", "Berat (gram)"
  sortOrder  Int      @default(0) @map("sort_order")
  isActive   Boolean  @default(true) @map("is_active")

  @@map("pricing_modes")
}

model ProductionOrder {
  poId       Int      @id @default(autoincrement()) @map("po_id")
  poNumber   String   @unique @map("po_number")
  customerId Int      @map("customer_id")
  designerId Int      @map("designer_id")
  status     String   @default("draft")
  priority   Int      @default(0)
  dueAt      DateTime? @map("due_at")
  notes      String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [customerId])
  designer User     @relation("designer", fields: [designerId], references: [userId])

  poDetails       PoDetail[]
  salesPos        SalesPos?
  deliveries      Delivery[]
  stockMovements  StockMovement[]

  @@map("production_orders")
}

model PoDetail {
  poDetailId Int     @id @default(autoincrement()) @map("po_detail_id")
  poId       Int     @map("po_id")
  productId  Int     @map("product_id")
  qty        Int
  size       String?
  fileUrl    String? @map("file_url")
  specNote   String? @map("spec_note") @db.Text

  // NEW - dipakai oleh checkout storefront, snapshot harga & spesifikasi kalkulator saat order dibuat
  unitPrice    Decimal? @map("unit_price") @db.Decimal(14, 2)
  lineTotal    Decimal? @map("line_total") @db.Decimal(14, 2)
  widthCm      Decimal? @map("width_cm") @db.Decimal(10, 2)
  heightCm     Decimal? @map("height_cm") @db.Decimal(10, 2)
  materialKey  String?  @map("material_key") // legacy, tidak diisi lagi sejak sistem opsi per-produk - lihat selectedOptions
  finishingKey String?  @map("finishing_key") // legacy, idem
  needDesign   Boolean  @default(false) @map("need_design")

  // NEW - snapshot pilihan opsi produk (label, bukan FK, supaya riwayat order tetap stabil
  // walau opsi diedit/dihapus manager belakangan). Bentuk: [{groupId,groupLabel,choiceId,choiceLabel}]
  selectedOptions Json?   @map("selected_options")
  designLink      String? @map("design_link") // link desain eksternal (Drive/Canva/dsb), sejajar fileUrl

  // NEW - link opsional ke Material yang dipakai item ini, supaya stok otomatis berkurang saat
  // ProductionTask-nya selesai (lihat production.service.js). Opsional & per-item (bukan resep/BOM
  // per produk) - staf isi kalau relevan, tidak wajib untuk semua order.
  materialId  Int?     @map("material_id")
  materialQty Decimal? @map("material_qty") @db.Decimal(14, 2)

  productionOrder ProductionOrder  @relation(fields: [poId], references: [poId])
  product         Product          @relation(fields: [productId], references: [productId])
  material        Material?        @relation(fields: [materialId], references: [materialId])
  productionTasks ProductionTask[]
  stockMovements  StockMovement[]

  @@map("po_details")
}

// ---------- M04: POS & Pembayaran ----------

model SalesPos {
  saleId     Int      @id @default(autoincrement()) @map("sale_id")
  poId       Int      @unique @map("po_id")
  cashierId  Int      @map("cashier_id")
  total      Decimal  @db.Decimal(14, 2)
  dp         Decimal  @default(0) @db.Decimal(14, 2)
  paidStatus String   @default("unpaid") @map("paid_status")
  createdAt  DateTime @default(now()) @map("created_at")

  productionOrder ProductionOrder @relation(fields: [poId], references: [poId])
  cashier         User            @relation("cashier", fields: [cashierId], references: [userId])
  payments        Payment[]

  @@map("sales_pos")
}

model Payment {
  paymentId   Int       @id @default(autoincrement()) @map("payment_id")
  saleId      Int       @map("sale_id")
  method      String
  amount      Decimal   @db.Decimal(14, 2)
  status      String    @default("confirmed") // 'confirmed' | 'pending' | 'rejected'
  proofUrl    String?   @map("proof_url") // bukti transfer yang diupload pelanggan storefront
  confirmedBy Int?      @map("confirmed_by")
  confirmedAt DateTime? @map("confirmed_at")
  paidAt      DateTime  @default(now()) @map("paid_at")

  sale            SalesPos @relation(fields: [saleId], references: [saleId])
  confirmedByUser User?    @relation(fields: [confirmedBy], references: [userId])

  @@map("payments")
}

// ---------- M05: Inventory ----------

model Material {
  materialId Int     @id @default(autoincrement()) @map("material_id")
  name       String
  unit       String
  stockQty   Decimal @default(0) @map("stock_qty") @db.Decimal(14, 2)
  minStock   Decimal @default(0) @map("min_stock") @db.Decimal(14, 2)
  avgCost    Decimal @default(0) @map("avg_cost") @db.Decimal(14, 2)

  stockMovements     StockMovement[]
  purchaseOrderItems PurchaseOrderItem[]
  poDetails          PoDetail[]

  @@map("materials")
}

model StockMovement {
  moveId     Int      @id @default(autoincrement()) @map("move_id")
  materialId Int      @map("material_id")
  poId       Int?     @map("po_id")
  // NEW - dipakai konsumsi otomatis dari production.service.js (lihat PoDetail.materialId/materialQty)
  // untuk cek idempotency: tanpa ini, task yang berpindah done->rework->done lagi bisa mengonsumsi
  // material dua kali. Nullable karena movement manual (dari inventory.service.js) tidak selalu
  // terkait satu PoDetail spesifik.
  poDetailId Int?     @map("po_detail_id")
  type       String   // in | out | reserve | adjustment
  qty        Decimal  @db.Decimal(14, 2)
  createdBy  Int?     @map("created_by")
  createdAt  DateTime @default(now()) @map("created_at")

  material        Material         @relation(fields: [materialId], references: [materialId])
  productionOrder ProductionOrder? @relation(fields: [poId], references: [poId])
  poDetail        PoDetail?        @relation(fields: [poDetailId], references: [poDetailId])

  @@map("stock_movements")
}

// ---------- M06: Produksi ----------

model Machine {
  machineId Int    @id @default(autoincrement()) @map("machine_id")
  name      String
  type      String?
  capacity  String?
  status    String @default("idle")

  productionTasks ProductionTask[]

  @@map("machines")
}

model ProductionTask {
  taskId     Int       @id @default(autoincrement()) @map("task_id")
  poDetailId Int       @map("po_detail_id")
  machineId  Int?      @map("machine_id")
  operatorId Int?      @map("operator_id")
  status     String    @default("queue")
  startAt    DateTime? @map("start_at")
  finishAt   DateTime? @map("finish_at")

  poDetail PoDetail @relation(fields: [poDetailId], references: [poDetailId])
  machine  Machine? @relation(fields: [machineId], references: [machineId])
  operator User?    @relation("operator", fields: [operatorId], references: [userId])
  qcChecks QcCheck[]

  @@map("production_tasks")
}

// ---------- M07: QC & Delivery ----------

model QcCheck {
  qcId      Int      @id @default(autoincrement()) @map("qc_id")
  taskId    Int      @map("task_id")
  qcBy      Int      @map("qc_by")
  result    String   // pass | fail
  issueType String?  @map("issue_type")
  photoUrl  String?  @map("photo_url")
  createdAt DateTime @default(now()) @map("created_at")

  task ProductionTask @relation(fields: [taskId], references: [taskId])
  qcBy_user User       @relation("qc_by", fields: [qcBy], references: [userId])

  @@map("qc_checks")
}

model Delivery {
  deliveryId Int      @id @default(autoincrement()) @map("delivery_id")
  poId       Int      @map("po_id")
  method     String   // pickup | delivery
  receiver   String?
  status     String   @default("pending")
  createdAt  DateTime @default(now()) @map("created_at")

  productionOrder ProductionOrder @relation(fields: [poId], references: [poId])

  @@map("deliveries")
}

// ---------- M08 / M10: Finance, Bonus & HRD Productivity ----------

model BonusRecord {
  bonusId Int      @id @default(autoincrement()) @map("bonus_id")
  userId  Int      @map("user_id")
  period  String   // e.g. "2026-07"
  source  String   // po | pos | production | qc | marketing
  score   Decimal  @db.Decimal(10, 2)
  amount  Decimal  @db.Decimal(14, 2)
  isAuto  Boolean  @default(false) @map("is_auto")

  user User @relation(fields: [userId], references: [userId])

  @@unique([userId, period, source])
  @@map("bonus_records")
}

model DailyKpi {
  kpiId  Int      @id @default(autoincrement()) @map("kpi_id")
  date   DateTime @db.Date
  role   String
  metric String
  value  Decimal  @db.Decimal(14, 2)
  userId Int?     @map("user_id")

  user User? @relation(fields: [userId], references: [userId])

  @@map("daily_kpis")
}

// ---------- M09: Marketing Campaign ----------

model Campaign {
  campaignId Int       @id @default(autoincrement()) @map("campaign_id")
  name       String
  channel    String?
  startDate  DateTime? @map("start_date") @db.Date
  endDate    DateTime? @map("end_date") @db.Date
  budget     Decimal   @default(0) @db.Decimal(14, 2)
  status     String    @default("planned") // planned | active | completed | cancelled
  notes      String?   @db.Text
  createdAt  DateTime  @default(now()) @map("created_at")

  @@map("campaigns")
}

// ---------- Storefront: Promo ----------

model Promo {
  promoId     Int       @id @default(autoincrement()) @map("promo_id")
  title       String
  description String?   @db.Text
  imageUrl    String?   @map("image_url")
  startDate   DateTime? @map("start_date") @db.Date
  endDate     DateTime? @map("end_date") @db.Date
  isActive    Boolean   @default(true) @map("is_active")
  sortOrder   Int       @default(0) @map("sort_order")
  updatedBy   Int?      @map("updated_by")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("promos")
}

// ---------- M12: Notification & Approval ----------

model Notification {
  notificationId Int      @id @default(autoincrement()) @map("notification_id")
  userId         Int      @map("user_id")
  type           String
  severity       String
  message        String   @db.Text
  refType        String?  @map("ref_type")
  refId          Int?     @map("ref_id")
  isRead         Boolean  @default(false) @map("is_read")
  createdAt      DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [userId])

  @@unique([userId, type, refType, refId])
  @@map("notifications")
}

// ---------- Finance extensions: Purchasing, Expense/Cash & Bank, Asset Management ----------

model CashAccount {
  cashAccountId  Int      @id @default(autoincrement()) @map("cash_account_id")
  name           String
  type           String // 'cash' | 'bank'
  bankName       String?  @map("bank_name")
  accountNumber  String?  @map("account_number")
  openingBalance Decimal  @default(0) @map("opening_balance") @db.Decimal(14, 2)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")

  expenses       Expense[]
  purchaseOrders PurchaseOrder[]

  @@map("cash_accounts")
}

model Expense {
  expenseId     Int      @id @default(autoincrement()) @map("expense_id")
  cashAccountId Int      @map("cash_account_id")
  category      String
  amount        Decimal  @db.Decimal(14, 2)
  expenseDate   DateTime @map("expense_date")
  description   String?  @db.Text
  createdBy     Int      @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")

  cashAccount CashAccount @relation(fields: [cashAccountId], references: [cashAccountId])
  creator     User        @relation(fields: [createdBy], references: [userId])

  @@map("expenses")
}

// Pembelian ke supplier (uang keluar) - terpisah dari ProductionOrder yang mewakili order penjualan
// masuk. Tidak otomatis update Material.stockQty (keputusan eksplisit user, di luar cakupan pass ini).
model PurchaseOrder {
  purchaseOrderId Int       @id @default(autoincrement()) @map("purchase_order_id")
  poNumber        String    @unique @map("po_number")
  supplierId      Int       @map("supplier_id")
  status          String    @default("draft") // draft -> ordered -> received -> paid ; cancelled dari draft/ordered
  orderDate       DateTime  @default(now()) @map("order_date")
  expectedDate    DateTime? @map("expected_date")
  paidAt          DateTime? @map("paid_at")
  cashAccountId   Int?      @map("cash_account_id") // diisi saat status -> paid
  totalAmount     Decimal   @default(0) @map("total_amount") @db.Decimal(14, 2) // denormalized sum(items)
  notes           String?   @db.Text
  createdBy       Int       @map("created_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  supplier    Supplier            @relation(fields: [supplierId], references: [supplierId])
  cashAccount CashAccount?        @relation(fields: [cashAccountId], references: [cashAccountId])
  creator     User                @relation(fields: [createdBy], references: [userId])
  items       PurchaseOrderItem[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  purchaseOrderItemId Int     @id @default(autoincrement()) @map("purchase_order_item_id")
  purchaseOrderId     Int     @map("purchase_order_id")
  materialId          Int?    @map("material_id") // opsional - tidak semua pembelian masuk katalog Material
  description         String
  qty                 Decimal @db.Decimal(14, 2)
  unitPrice           Decimal @map("unit_price") @db.Decimal(14, 2)
  lineTotal           Decimal @map("line_total") @db.Decimal(14, 2)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [purchaseOrderId], onDelete: Cascade)
  material      Material?     @relation(fields: [materialId], references: [materialId])

  @@map("purchase_order_items")
}

model Asset {
  assetId         Int       @id @default(autoincrement()) @map("asset_id")
  name            String
  category        String?
  acquisitionDate DateTime? @map("acquisition_date")
  acquisitionCost Decimal?  @map("acquisition_cost") @db.Decimal(14, 2)
  currentValue    Decimal?  @map("current_value") @db.Decimal(14, 2)
  location        String?
  status          String    @default("active") // active | maintenance | disposed
  notes           String?   @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("assets")
}
