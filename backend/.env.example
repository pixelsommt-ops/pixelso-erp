PORT=4000
NODE_ENV=development

DATABASE_URL="mysql://user:password@localhost:3306/pixelso_erp"

JWT_SECRET=change_this_secret
JWT_EXPIRES_IN=8h

CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Shared secret for the landing page's server-to-server pricing fetch (GET /api/public/pricing)
LANDING_PAGE_API_KEY=change_this_shared_secret

# Customer (storefront) auth - deliberately a different secret than staff JWT_SECRET
CUSTOMER_JWT_SECRET=change_this_other_secret
CUSTOMER_JWT_EXPIRES_IN=30d
STOREFRONT_UPLOAD_MAX_DESIGN_BYTES=52428800
STOREFRONT_UPLOAD_MAX_PROOF_BYTES=3000000
PRICING_UPLOAD_MAX_PHOTO_BYTES=5000000

# Kirim email "Lupa Password" via Gmail SMTP - GMAIL_APP_PASSWORD adalah App Password 16-karakter
# dari myaccount.google.com/apppasswords (bukan password akun Gmail biasa), butuh 2FA aktif dulu.
GMAIL_USER=
GMAIL_APP_PASSWORD=
# Base URL storefront untuk link di email reset password, mis. https://cetakpixelso.com
STOREFRONT_URL=http://localhost:5174

# Login "Sign in with Google" - Client ID dari Google Cloud Console (OAuth consent screen +
# credentials untuk domain cetakpixelso.com). Sama nilainya dengan storefront's VITE_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=
