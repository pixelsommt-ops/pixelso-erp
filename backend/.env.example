PORT=4000
NODE_ENV=development

DATABASE_URL="mysql://user:password@localhost:3306/pixelso_erp"

JWT_SECRET=change_this_secret
JWT_EXPIRES_IN=8h

CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Shared secret for the landing page's server-to-server pricing fetch (GET /api/public/pricing)
LANDING_PAGE_API_KEY=change_this_shared_secret

# Customer (storefront) auth - deliberately a different secret than staff JWT_SECRET
CUSTOMER_JWT_SECRET=change_this_other_secret
CUSTOMER_JWT_EXPIRES_IN=30d
STOREFRONT_UPLOAD_MAX_DESIGN_BYTES=52428800
STOREFRONT_UPLOAD_MAX_PROOF_BYTES=3000000
PRICING_UPLOAD_MAX_PHOTO_BYTES=5000000
